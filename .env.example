NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=
SUPABASE_DB_URL=
RUNPOD_API_KEY=
RUNPOD_DEFAULT_REGION=US
RUNPOD_DEFAULT_GPU_TYPE=NVIDIA H100 80GB HBM3
RUNPOD_DEFAULT_GPU_COUNT=8
RUNPOD_DEFAULT_VOLUME_GB=2000
RUNPOD_DEFAULT_CONTAINER_IMAGE=ghcr.io/wyndme/llama405b-vllm:latest
HF_TOKEN=
MODEL_ID=meta-llama/Meta-Llama-3.1-405B-Instruct
MODEL_CACHE_DIR=/workspace/models
MODEL_QUANTIZATION=fp8
LLAMA_SERVER_URL=http://localhost:8000
LLAMA_SERVER_API_KEY=
LLAMA_CONTEXT_LENGTH=32768
LLAMA_MAX_MODEL_LEN=32768
LLAMA_TENSOR_PARALLEL_SIZE=8
LLAMA_PIPELINE_PARALLEL_SIZE=1
LLAMA_GPU_MEMORY_UTILIZATION=0.90
GITHUB_TOKEN=
GITHUB_ORG=
GITHUB_DEFAULT_PRIVATE=true
ENCRYPTION_KEY=
JWT_SECRET=
ADMIN_API_KEY=
ADMIN_EMAIL=
ALLOW_EXTERNAL_MODEL_PROVIDERS=false
DEFAULT_SESSION_HOURS=4
MAX_SESSION_HOURS=4
MAX_DAILY_GPU_BUDGET_USD=
REQUIRE_APPROVAL_ABOVE_USD=
AUTO_STOP_ENABLED=true
PLAYWRIGHT_ENABLED=true
BROWSER_SANDBOX=true

# Multi-model routing
LLAMA_REASONING_MODEL_ID=meta-llama/Meta-Llama-3.1-405B-Instruct
LLAMA_SERVED_MODEL_NAME=wyndme-llama-405b
LLAMA_GPU_PROFILE=8xH100-80GB
QWEN_CODER_MODEL_ID=Qwen/Qwen3-Coder-480B-A35B-Instruct-FP8
