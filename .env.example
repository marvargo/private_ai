QWEN_SERVER_API_KEY=
QWEN_CONTEXT_LENGTH=262144
QWEN_TENSOR_PARALLEL_SIZE=4
QWEN_GPU_PROFILE=4xH100-80GB-or-cheaper-compatible
TEST_MODEL_ID=Qwen/Qwen3-Coder-30B-A3B-Instruct-FP8
TEST_MODEL_ENABLED=true
